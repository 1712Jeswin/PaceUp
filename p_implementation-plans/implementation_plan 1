### 2. Database Schema (Prisma)

#### [NEW] `prisma/schema.prisma`

```prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserLevel {
  BEGINNER
  MID
  ADVANCED
}

enum AIProvider {
  CLAUDE
  OPENAI
  GEMINI
  GROK
}

enum BriefStatus {
  DRAFT
  ANALYSED
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  DONE
  OVERDUE
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  name      String
  email     String   @unique
  skills    Json     @default("[]")   // JSON array of language strings
  domains   Json     @default("[]")   // JSON array of domain strings
  level     UserLevel?                // nullable until profile setup
  createdAt DateTime @default(now())

  groupsCreated  Group[]        @relation("GroupCreator")
  groupMembers   GroupMember[]
  tasks          Task[]
  aiKeys         AIKey[]

  @@index([clerkId])
  @@index([email])
}

model Group {
  id         String   @id @default(cuid())
  name       String
  inviteCode String   @unique @db.VarChar(8)
  createdById String
  createdBy  User     @relation("GroupCreator", fields: [createdById], references: [id])
  createdAt  DateTime @default(now())

  members      GroupMember[]
  projectBrief ProjectBrief?  // one-to-one reverse relation

  @@index([inviteCode])
  @@index([createdById])
}

model GroupMember {
  id       String   @id @default(cuid())
  groupId  String
  userId   String
  role     String?             // AI-assigned, nullable until brief analysed
  joinedAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])  // prevent duplicate membership
  @@index([groupId])
  @@index([userId])
}

model ProjectBrief {
  id                String      @id @default(cuid())
  groupId           String      @unique  // one brief per group
  ideaStatement     String      @db.Text
  solutionApproach  String      @db.Text
  deadline          DateTime
  scopeStatement    String      @db.Text
  status            BriefStatus @default(DRAFT)
  createdAt         DateTime    @default(now())

  group Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([groupId])
}

model Task {
  id              String     @id @default(cuid())
  projectBriefId  String
  assignedUserId  String
  title           String
  description     String     @db.Text
  estimatedDays   Int
  status          TaskStatus @default(NOT_STARTED)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  projectBrief ProjectBrief @relation(fields: [projectBriefId], references: [id], onDelete: Cascade)
  assignedUser User         @relation(fields: [assignedUserId], references: [id])

  @@index([projectBriefId])
  @@index([assignedUserId])
  @@index([status])
}

model AIKey {
  id           String     @id @default(cuid())
  userId       String
  provider     AIProvider
  encryptedKey String     @db.Text
  modelName    String
  isActive     Boolean    @default(false)
  createdAt    DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])  // one key per provider per user
  @@index([userId])
  @@index([userId, isActive])
}
```

**Key design decisions:**
- `Group.projectBriefId` removed — use `ProjectBrief.groupId` (unique) for the 1:1 relation
- `GroupMember` has `@@unique([groupId, userId])` to prevent double-joins
- `AIKey` has `@@unique([userId, provider])` — one key per provider per user
- `Json` type for `skills` and `domains` — arrays of strings stored as JSON
- `UserLevel` is nullable — null until profile setup is complete
- All FK columns have indexes for query performance
- `Task.status` indexed for filtering

