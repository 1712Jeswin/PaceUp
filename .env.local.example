# ============================================
# PACEUP — Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.

# ---- Neon / Prisma ----
# PostgreSQL connection string from your Neon dashboard
DATABASE_URL=

# ---- Clerk ----
# From Clerk Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# From Clerk Dashboard → Webhooks → Signing Secret
CLERK_WEBHOOK_SECRET=

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard/profile/setup

# ---- AI Key Encryption ----
# 32-character random string used to encrypt user API keys at rest
# Generate with: openssl rand -hex 16
AI_KEY_SECRET=

# ---- Resend (email) ----
# From Resend Dashboard → API Keys
# Phase 1: set up client only, no emails sent yet
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ---- Upstash Redis ----
# From Upstash Console → REST API credentials
# Phase 1: set up client only, no queues yet
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- GitHub Integration (Phase 2) ----
# GITHUB_WEBHOOK_SECRET=

# ---- Vercel Cron Protection (Phase 2) ----
# CRON_SECRET=

# ---- Stripe (Phase 4) ----
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
