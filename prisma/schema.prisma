generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserLevel {
  BEGINNER
  MID
  ADVANCED
}

enum AIProvider {
  CLAUDE
  OPENAI
  GEMINI
  GROK
}

enum BriefStatus {
  DRAFT
  ANALYSED
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  DONE
  OVERDUE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum InvitationType {
  JOIN_REQUEST
  EMAIL_INVITE
  IN_APP_INVITE
}

// Phase 2 enums

enum PRStatus {
  OPEN
  MERGED
  CLOSED
}

enum ConfidenceLevel {
  HIGH
  MEDIUM
  LOW
}

enum NotificationType {
  TASK_OVERDUE
  STANDUP_MISSING
  CONFLICT_DETECTED
  REVIEW_REQUIRED
}

enum ReviewResult {
  PASS
  FAIL
  NEEDS_REVISION
}

// ============================================
// MODELS
// ============================================

/// Synced from Clerk via webhook. Stores skill profile data.
model User {
  id        String     @id @default(cuid())
  clerkId   String     @unique
  userCode  String?    @unique @db.VarChar(8)
  name      String
  email     String     @unique
  skills      Json       @default("[]")
  domains     Json       @default("[]")
  level       UserLevel?
  profileData Json?
  resumeText  String?    @db.Text
  createdAt   DateTime   @default(now())

  groupsCreated        Group[]       @relation("GroupCreator")
  groupMembers         GroupMember[]
  tasks                Task[]
  aiKeys               AIKey[]
  invitationsReceived  Invitation[]  @relation("InvitationTarget")
  invitationsInitiated Invitation[]  @relation("InvitationInitiator")
  standups             StandupResponse[]
  notifications        Notification[]

  @@index([clerkId])
  @@index([email])
  @@index([userCode])
}

/// A project group created by a user. Members join via invite code.
model Group {
  id          String   @id @default(cuid())
  name        String
  inviteCode  String   @unique @db.VarChar(8)
  createdById String
  createdBy   User     @relation("GroupCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  // Phase 2: GitHub integration fields
  githubRepoUrl   String?
  githubWebhookId String?
  githubPat       String?  @db.Text  // Encrypted GitHub PAT for webhook registration

  members        GroupMember[]
  projectBrief   ProjectBrief?
  invitations    Invitation[]
  commits        Commit[]
  pullRequests   PullRequest[]
  conflictAlerts ConflictAlert[]
  standups       StandupResponse[]
  notifications  Notification[]

  @@index([inviteCode])
  @@index([createdById])
}

/// Join table: which users belong to which groups.
/// Role is AI-assigned after the project brief is analysed.
/// isActive tracks whether the user has left the group (for Previous Groups history).
model GroupMember {
  id       String    @id @default(cuid())
  groupId  String
  userId   String
  role     String?
  isActive Boolean   @default(true)
  joinedAt DateTime  @default(now())
  leftAt   DateTime?

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
  @@index([isActive])
}

/// The project brief submitted by the group creator.
/// One brief per group (enforced by unique groupId).
model ProjectBrief {
  id               String      @id @default(cuid())
  groupId          String      @unique
  ideaStatement    String      @db.Text
  solutionApproach String      @db.Text
  deadline         DateTime
  scopeStatement   String      @db.Text
  status           BriefStatus @default(DRAFT)
  createdAt        DateTime    @default(now())

  group Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([groupId])
}

/// A task assigned to a group member by the AI.
model Task {
  id             String     @id @default(cuid())
  projectBriefId String
  assignedUserId String
  title          String
  description    String     @db.Text
  estimatedDays  Int
  status         TaskStatus @default(NOT_STARTED)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  projectBrief   ProjectBrief   @relation(fields: [projectBriefId], references: [id], onDelete: Cascade)
  assignedUser   User           @relation(fields: [assignedUserId], references: [id])
  commitLinks    CommitTaskLink[]
  codeReviews    CodeReview[]

  @@index([projectBriefId])
  @@index([assignedUserId])
  @@index([status])
}

/// User's encrypted API keys for AI providers (BYOK model).
/// One key per provider per user. Only one can be active at a time.
model AIKey {
  id           String     @id @default(cuid())
  userId       String
  provider     AIProvider
  encryptedKey String     @db.Text
  modelName    String
  isActive     Boolean    @default(false)
  createdAt    DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@index([userId, isActive])
}

/// Tracks join requests and invitations for groups.
/// Type determines direction: JOIN_REQUEST (user→group), IN_APP_INVITE/EMAIL_INVITE (creator→user).
model Invitation {
  id            String           @id @default(cuid())
  groupId       String
  type          InvitationType
  status        InvitationStatus @default(PENDING)

  /// For JOIN_REQUEST: the user who wants to join.
  /// For IN_APP_INVITE: the user being invited.
  userId        String?

  /// For EMAIL_INVITE: the email of the person being invited.
  email         String?

  /// Who initiated this invitation (creator for invites, the user for join requests).
  initiatedById String

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  group       Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user        User? @relation("InvitationTarget", fields: [userId], references: [id])
  initiatedBy User  @relation("InvitationInitiator", fields: [initiatedById], references: [id])

  @@unique([groupId, userId, type])
  @@index([groupId])
  @@index([userId])
  @@index([status])
}

// ============================================
// PHASE 2 MODELS
// ============================================

/// A Git commit ingested from a GitHub webhook push event.
model Commit {
  id                   String   @id @default(cuid())
  groupId              String
  authorGithubUsername String
  sha                  String   @unique
  message              String   @db.Text
  filesChanged         Json     @default("[]")  // JSON array of filenames
  timestamp            DateTime
  createdAt            DateTime @default(now())

  group     Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  taskLinks CommitTaskLink[]

  @@index([groupId])
  @@index([sha])
  @@index([groupId, timestamp])
}

/// A pull request ingested from a GitHub webhook pull_request event.
model PullRequest {
  id                   String   @id @default(cuid())
  groupId              String
  number               Int
  title                String
  authorGithubUsername String
  status               PRStatus @default(OPEN)
  createdAt            DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, number])
  @@index([groupId])
}

/// Links a commit to a task with AI-determined confidence.
model CommitTaskLink {
  id         String          @id @default(cuid())
  commitId   String
  taskId     String
  confidence ConfidenceLevel
  createdAt  DateTime        @default(now())

  commit Commit @relation(fields: [commitId], references: [id], onDelete: Cascade)
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([commitId, taskId])
  @@index([commitId])
  @@index([taskId])
}

/// Tracks file conflicts when multiple members edit the same file on the same day.
model ConflictAlert {
  id         String    @id @default(cuid())
  groupId    String
  filename   String
  memberIds  Json      @default("[]")  // JSON array of user IDs involved
  detectedAt DateTime  @default(now())
  resolvedAt DateTime?

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([groupId, resolvedAt])
}

/// A daily standup response from a team member.
model StandupResponse {
  id           String   @id @default(cuid())
  userId       String
  groupId      String
  date         DateTime @db.Date  // Date only, no time component
  didYesterday String   @db.Text
  planToday    String   @db.Text
  blockers     String?  @db.Text
  submittedAt  DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId, date])
  @@index([groupId, date])
  @@index([userId])
}

/// In-app notification for nag loop alerts, review results, etc.
model Notification {
  id        String           @id @default(cuid())
  userId    String
  groupId   String?
  type      NotificationType
  message   String           @db.Text
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group? @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, readAt])
  @@index([groupId])
}

/// AI code review result for a task.
model CodeReview {
  id         String       @id @default(cuid())
  taskId     String
  reviewedBy String       // userId of the group creator who triggered the review
  result     ReviewResult
  feedback   String       @db.Text
  issues     Json         @default("[]")  // JSON array of issue strings
  createdAt  DateTime     @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}
