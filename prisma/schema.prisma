generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserLevel {
  BEGINNER
  MID
  ADVANCED
}

enum AIProvider {
  CLAUDE
  OPENAI
  GEMINI
  GROK
}

enum BriefStatus {
  DRAFT
  ANALYSED
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  DONE
  OVERDUE
}

// ============================================
// MODELS
// ============================================

/// Synced from Clerk via webhook. Stores skill profile data.
model User {
  id        String     @id @default(cuid())
  clerkId   String     @unique
  name      String
  email     String     @unique
  skills    Json       @default("[]")
  domains   Json       @default("[]")
  level     UserLevel?
  createdAt DateTime   @default(now())

  groupsCreated Group[]       @relation("GroupCreator")
  groupMembers  GroupMember[]
  tasks         Task[]
  aiKeys        AIKey[]

  @@index([clerkId])
  @@index([email])
}

/// A project group created by a user. Members join via invite code.
model Group {
  id          String   @id @default(cuid())
  name        String
  inviteCode  String   @unique @db.VarChar(8)
  createdById String
  createdBy   User     @relation("GroupCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  members      GroupMember[]
  projectBrief ProjectBrief?

  @@index([inviteCode])
  @@index([createdById])
}

/// Join table: which users belong to which groups.
/// Role is AI-assigned after the project brief is analysed.
model GroupMember {
  id       String   @id @default(cuid())
  groupId  String
  userId   String
  role     String?
  joinedAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
}

/// The project brief submitted by the group creator.
/// One brief per group (enforced by unique groupId).
model ProjectBrief {
  id               String      @id @default(cuid())
  groupId          String      @unique
  ideaStatement    String      @db.Text
  solutionApproach String      @db.Text
  deadline         DateTime
  scopeStatement   String      @db.Text
  status           BriefStatus @default(DRAFT)
  createdAt        DateTime    @default(now())

  group Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([groupId])
}

/// A task assigned to a group member by the AI.
model Task {
  id             String     @id @default(cuid())
  projectBriefId String
  assignedUserId String
  title          String
  description    String     @db.Text
  estimatedDays  Int
  status         TaskStatus @default(NOT_STARTED)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  projectBrief ProjectBrief @relation(fields: [projectBriefId], references: [id], onDelete: Cascade)
  assignedUser User         @relation(fields: [assignedUserId], references: [id])

  @@index([projectBriefId])
  @@index([assignedUserId])
  @@index([status])
}

/// User's encrypted API keys for AI providers (BYOK model).
/// One key per provider per user. Only one can be active at a time.
model AIKey {
  id           String     @id @default(cuid())
  userId       String
  provider     AIProvider
  encryptedKey String     @db.Text
  modelName    String
  isActive     Boolean    @default(false)
  createdAt    DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@index([userId, isActive])
}
