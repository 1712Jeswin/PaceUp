generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserLevel {
  BEGINNER
  MID
  ADVANCED
}

enum AIProvider {
  CLAUDE
  OPENAI
  GEMINI
  GROK
}

enum BriefStatus {
  DRAFT
  ANALYSED
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  DONE
  OVERDUE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum InvitationType {
  JOIN_REQUEST
  EMAIL_INVITE
  IN_APP_INVITE
}

// ============================================
// MODELS
// ============================================

/// Synced from Clerk via webhook. Stores skill profile data.
model User {
  id        String     @id @default(cuid())
  clerkId   String     @unique
  userCode  String?    @unique @db.VarChar(8)
  name      String
  email     String     @unique
  skills    Json       @default("[]")
  domains   Json       @default("[]")
  level     UserLevel?
  createdAt DateTime   @default(now())

  groupsCreated        Group[]       @relation("GroupCreator")
  groupMembers         GroupMember[]
  tasks                Task[]
  aiKeys               AIKey[]
  invitationsReceived  Invitation[]  @relation("InvitationTarget")
  invitationsInitiated Invitation[]  @relation("InvitationInitiator")

  @@index([clerkId])
  @@index([email])
  @@index([userCode])
}

/// A project group created by a user. Members join via invite code.
model Group {
  id          String   @id @default(cuid())
  name        String
  inviteCode  String   @unique @db.VarChar(8)
  createdById String
  createdBy   User     @relation("GroupCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  members      GroupMember[]
  projectBrief ProjectBrief?
  invitations  Invitation[]

  @@index([inviteCode])
  @@index([createdById])
}

/// Join table: which users belong to which groups.
/// Role is AI-assigned after the project brief is analysed.
/// isActive tracks whether the user has left the group (for Previous Groups history).
model GroupMember {
  id       String    @id @default(cuid())
  groupId  String
  userId   String
  role     String?
  isActive Boolean   @default(true)
  joinedAt DateTime  @default(now())
  leftAt   DateTime?

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
  @@index([isActive])
}

/// The project brief submitted by the group creator.
/// One brief per group (enforced by unique groupId).
model ProjectBrief {
  id               String      @id @default(cuid())
  groupId          String      @unique
  ideaStatement    String      @db.Text
  solutionApproach String      @db.Text
  deadline         DateTime
  scopeStatement   String      @db.Text
  status           BriefStatus @default(DRAFT)
  createdAt        DateTime    @default(now())

  group Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([groupId])
}

/// A task assigned to a group member by the AI.
model Task {
  id             String     @id @default(cuid())
  projectBriefId String
  assignedUserId String
  title          String
  description    String     @db.Text
  estimatedDays  Int
  status         TaskStatus @default(NOT_STARTED)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  projectBrief ProjectBrief @relation(fields: [projectBriefId], references: [id], onDelete: Cascade)
  assignedUser User         @relation(fields: [assignedUserId], references: [id])

  @@index([projectBriefId])
  @@index([assignedUserId])
  @@index([status])
}

/// User's encrypted API keys for AI providers (BYOK model).
/// One key per provider per user. Only one can be active at a time.
model AIKey {
  id           String     @id @default(cuid())
  userId       String
  provider     AIProvider
  encryptedKey String     @db.Text
  modelName    String
  isActive     Boolean    @default(false)
  createdAt    DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@index([userId, isActive])
}

/// Tracks join requests and invitations for groups.
/// Type determines direction: JOIN_REQUEST (user→group), IN_APP_INVITE/EMAIL_INVITE (creator→user).
model Invitation {
  id            String           @id @default(cuid())
  groupId       String
  type          InvitationType
  status        InvitationStatus @default(PENDING)

  /// For JOIN_REQUEST: the user who wants to join.
  /// For IN_APP_INVITE: the user being invited.
  userId        String?

  /// For EMAIL_INVITE: the email of the person being invited.
  email         String?

  /// Who initiated this invitation (creator for invites, the user for join requests).
  initiatedById String

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  group       Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user        User? @relation("InvitationTarget", fields: [userId], references: [id])
  initiatedBy User  @relation("InvitationInitiator", fields: [initiatedById], references: [id])

  @@unique([groupId, userId, type])
  @@index([groupId])
  @@index([userId])
  @@index([status])
}
